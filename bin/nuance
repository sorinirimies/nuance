#!/usr/bin/env bash
# nuance — CLI usable from any shell (bash/zsh/fish/…).
#   nuance theme [name]          show all themes, or set + pin one
#   nuance prompt-style [name]   show all styles, or set one
#   nuance look [name]           list looks, or apply one
#   nuance update                pull the checkout, then reload Nushell
#   nuance help                  this help
# The same commands (theme/prompt-style/look/update) also work inside Nushell.
set -euo pipefail

REPO_URL="https://github.com/sorinirimies/nuance.git"

info() { printf '\033[1;32m==>\033[0m %s\n' "$*"; }
warn() { printf '\033[1;33m!  \033[0m %s\n' "$*"; }
die()  { printf '\033[1;31mx  \033[0m %s\n' "$*" >&2; exit 1; }
have() { command -v "$1" >/dev/null 2>&1; }

have nu || die "Nushell (nu) is required — install it or run the bootstrap."

autoload_file() { printf '%s/nushell-prompt.nu' "$(nu -n -c '$nu.user-autoload-dirs | get 0' 2>/dev/null)"; }

# Run a nuance command in a throwaway Nushell (applies persist to state files).
run_nu() {
  local f; f="$(autoload_file)"
  [ -e "$f" ] || die "nuance is not installed (no $f)"
  nu -n -c "source \"$f\"; $*"
}

# Resolve the git checkout from the autoload symlink.
repo_dir() {
  local f real; f="$(autoload_file)"
  [ -e "$f" ] || return 0
  if have realpath; then dirname "$(realpath "$f")"
  elif have python3; then python3 -c 'import os,sys;print(os.path.dirname(os.path.realpath(sys.argv[1])))' "$f"
  else real="$f"; while [ -L "$real" ]; do real="$(readlink "$real")"; done; ( cd "$(dirname "$f")" && cd "$(dirname "$real")" && pwd ); fi
}

usage() {
  cat <<'EOF'
nuance — themeable, git-aware Nushell prompt

  nuance theme [name]          show all themes, or set + pin one
  nuance prompt-style [name]   show all styles, or set one
  nuance look [name]           list looks, or apply one (theme + style)
  nuance update                pull the latest, then: exec nu
  nuance help                  this help

Set from a normal shell → applies to your next Nushell (run: exec nu).
EOF
}

cmd_update() {
  local dir; dir="$(repo_dir || true)"
  if [ -n "${dir:-}" ] && [ -d "$dir/.git" ]; then
    info "updating $dir …"
    git -C "$dir" pull --ff-only
    printf '\033[1;32m✓\033[0m updated — open a new shell (or run: exec nu)\n'
  else
    warn "no git checkout found (copy/bootstrap install) — re-run the bootstrap:"
    echo "  curl -fsSL https://raw.githubusercontent.com/sorinirimies/nuance/main/bootstrap.sh | bash"
  fi
}

case "${1:-help}" in
  theme)         shift; run_nu "nuance theme ${*:-}" ;;
  prompt-style)  shift; run_nu "nuance prompt-style ${*:-}" ;;
  look)          shift; run_nu "nuance look ${*:-}" ;;
  update)        cmd_update ;;
  help|-h|--help) usage ;;
  *) usage; exit 1 ;;
esac
